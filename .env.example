# ═══════════════════════════════════════════════════════════════
# ELOKO Backend — Configuration Environnement
# ═══════════════════════════════════════════════════════════════
# 
# À copier en .env et remplir avec vos valeurs réelles
# python: 3.14+ | fastapi 0.115+ | pydantic 2.11+
#
# ═══════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────
APP_NAME=ELOKO
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
DEFAULT_LANGUAGE=fr

# ─── Security (Secrets & Authentication) ──────────────────────
# 🔐 IMPORTANT: Changez SECRET_KEY en production!
# Générez une clé forte: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=eloko2026secretkey_change_in_production

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP (2FA par email)
OTP_EXPIRE_SECONDS=600
MAX_LOGIN_ATTEMPTS=5

# ─── Database (PostgreSQL + asyncpg) ──────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/database
# Exemple local: postgresql+asyncpg://postgres:password@localhost:5432/eloko_db
DATABASE_URL=postgresql+asyncpg://tp-1:ESPORT2004.com@localhost:5432/eloko_db

# ─── MongoDB (Sessions & Cache) ───────────────────────────────
MONGODB_URL=mongodb://localhost:27017/eloko_sessions

# ─── Modules internes (URLs des autres services) ──────────────
MARKET_MODULE_URL=http://localhost:8001
COLLECTION_MODULE_URL=http://localhost:8002
PREDICTION_MODULE_URL=http://localhost:8003

# ─── Email (SMTP Configuration) ───────────────────────────────
# Pour Gmail: utilisez une "App Password" (pas votre mot de passe Google)
# https://support.google.com/accounts/answer/185833
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-16-chars
MAIL_FROM=noreply@eloko.africa
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ─── Paiements (Stripe, Orange Money, MTN Mobile Money, Wave) ─
STRIPE_SECRET_KEY=sk_test_your_stripe_key
ORANGE_MONEY_API_KEY=your_orange_money_api_key
MTN_MOMO_API_KEY=your_mtn_momo_api_key
WAVE_API_KEY=your_wave_api_key

# ─── CORS (Cross-Origin Resource Sharing) ────────────────────
# Domaines autorisés (format JSON array - IMPORTANT!)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","https://app.eloko.africa"]

